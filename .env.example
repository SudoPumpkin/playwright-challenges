# Server Configuration
# Port for the Express server
PORT=3000

# Environment mode (development/production)
NODE_ENV=development

# Playwright Test Configuration
# Note: BASE_URL automatically syncs with PORT if not set. Only set BASE_URL if you need to override it.
# When BASE_URL points to a remote server (not localhost), the local webServer will not be started.
# BASE_URL=http://localhost:3000     # Base URL for tests (optional - defaults to http://localhost:${PORT})
# BASE_URL=https://staging.example.com  # Example: Test against a remote server
# Run browser in headless mode (true/false)
HEADLESS=false

# Test Credentials (for future authentication scenarios)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=password123

# Timeouts (milliseconds)
# Overall test timeout (2 minutes)
DEFAULT_TIMEOUT=120000

# Page navigation timeout (15 seconds)
NAVIGATION_TIMEOUT=15000

# Browser Configuration
# Browser to use (chromium/firefox/webkit)
BROWSER=chromium

# Slow down operations by N milliseconds (useful for debugging)
SLOW_MO=0

# Debugging
# Enable debug mode
DEBUG=false

# Trace mode: on, off, retain-on-failure, on-first-retry (invalid values fall back to retain-on-failure)
TRACE=retain-on-failure
