# Server Configuration
PORT=3000                    # Port for the Express server
NODE_ENV=development         # Environment mode (development/production)

# Playwright Test Configuration
BASE_URL=http://localhost:3000     # Base URL for tests
HEADLESS=false                      # Run browser in headless mode (true/false)

# Test Credentials (for future authentication scenarios)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=password123

# Timeouts (milliseconds)
DEFAULT_TIMEOUT=120000        # Overall test timeout (2 minutes)
NAVIGATION_TIMEOUT=15000      # Page navigation timeout (15 seconds)

# Browser Configuration
BROWSER=chromium              # Browser to use (chromium/firefox/webkit)
SLOW_MO=0                     # Slow down operations by N milliseconds (useful for debugging)

# Debugging
DEBUG=false                   # Enable debug mode
TRACE=retain-on-failure       # Trace mode: on, off, retain-on-failure, on-first-retry
